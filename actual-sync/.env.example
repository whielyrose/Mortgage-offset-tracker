# ── Actual Budget connection ──────────────────────────────────────────────────
# Your Actual Budget server URL (Tailscale IP or local network address)
ACTUAL_SERVER_URL=http://100.x.x.x:5006

# Your Actual Budget server password
ACTUAL_SERVER_PASSWORD=your-actual-password-here

# Your budget's Sync ID — found in Actual: Settings → Show advanced settings
ACTUAL_SYNC_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Only needed if your budget file is encrypted with a separate password
# ACTUAL_FILE_PASSWORD=your-file-password

# ── Mortgage Tracker API ──────────────────────────────────────────────────────
# Internal Docker network URL of the mortgage tracker API container
# Use the container name — Docker resolves it automatically within the stack
MORTGAGE_API_URL=http://mortgage-tracker-api:8000

# ── Options ───────────────────────────────────────────────────────────────────
# Set to "true" to test without writing any data
# DRY_RUN=true
